################################################################################
# Celo Agent Preflight
# Copy to .env.local for local web dev and .env for CLI/Foundry scripts.
################################################################################

# App identity
NEXT_PUBLIC_APP_NAME="Celo Agent Preflight"
NEXT_PUBLIC_APP_URL="https://celo-agent-preflight.vercel.app"
NEXT_PUBLIC_REPORT_BASE_URL="https://celo-agent-preflight.vercel.app/reports"
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/cleanerzkp/celo-agent-preflight"
NEXT_PUBLIC_DOCS_URL="https://github.com/cleanerzkp/celo-agent-preflight/tree/master/docs"
SCANNER_VERSION="0.1.0"
GIT_SHA="local"

# Database / backend index
DATABASE_URL="postgresql://..."
DIRECT_DATABASE_URL="postgresql://..."
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""

# Queue / worker
PGBOSS_SCHEMA="pgboss"
WORKER_CONCURRENCY="5"
AGENTPROOF_WORKER_SCAN_TARGETS=""
AGENTPROOF_REPORT_DIR="./storage/reports"

# Celo RPCs
CELO_RPC_URL="https://forno.celo.org"
CELO_MAINNET_RPC_URL="https://forno.celo.org"
CELO_SEPOLIA_RPC_URL="https://forno.celo-sepolia.celo-testnet.org"
CELO_TESTNET_RPC_URL="https://forno.celo-sepolia.celo-testnet.org"
NEXT_PUBLIC_CELO_MAINNET_CHAIN_ID="42220"
NEXT_PUBLIC_CELO_SEPOLIA_CHAIN_ID="11142220"

# ERC-8004 Celo deployments
NEXT_PUBLIC_ERC8004_IDENTITY_REGISTRY_CELO="0x8004A169FB4a3325136EB29fA0ceB6D2e539a432"
NEXT_PUBLIC_ERC8004_REPUTATION_REGISTRY_CELO="0x8004BAa17C55a88189AE136b182e5fdA19dE9b63"
NEXT_PUBLIC_ERC8004_IDENTITY_REGISTRY_CELO_SEPOLIA="0x8004A818BFB912233c491871b3d84c89A494BD9e"
NEXT_PUBLIC_ERC8004_REPUTATION_REGISTRY_CELO_SEPOLIA="0x8004B663056A597Dffe9eCcC1965A193B7388713"

# Preflight attestation contract deployments
NEXT_PUBLIC_PREFLIGHT_ATTESTATION_CELO=""
NEXT_PUBLIC_PREFLIGHT_ATTESTATION_CELO_SEPOLIA=""

# Deployment / attestation wallets
# Use dedicated low-balance wallets. Never commit real values.
DEPLOYER_PRIVATE_KEY=""
ATTESTER_PRIVATE_KEY=""
ATTESTER_ADDRESS=""
GRANT_L2_DELIVERY_ADDRESS=""

# Fee abstraction and payment tokens
CELO_MAINNET_USDC="0xcebA9300f2b948710d2653dD7B07f33A8B32118C"
CELO_MAINNET_USDT="0x48065fbbe25f71c9282ddf5e1cd6d6a887483d5e"
CELO_MAINNET_USDM="0x765DE816845861e75A25fCA122bb6898B8B1282a"
CELO_MAINNET_USDC_FEE_ADAPTER="0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B"
CELO_MAINNET_USDT_FEE_ADAPTER="0x0e2a3e05bc9a16f5292a6170456a710cb89c6f72"
CELO_SEPOLIA_USDC="0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B"
CELO_SEPOLIA_USDC_FEE_ADAPTER="0x4822e58de6f5e485eF90df51C41CE01721331dC0"

# x402 / thirdweb optional integration
THIRDWEB_CLIENT_ID=""
THIRDWEB_SECRET_KEY=""
X402_TEST_CLIENT_PRIVATE_KEY=""
X402_TEST_MAX_USD="0.05"

# Self Agent ID
SELF_API_KEY=""
SELF_AGENT_ID=""
SELF_AGENT_ID_LOOKUP_URL=""
SELF_AGENT_ID_DOCS_URL="https://docs.self.xyz/"

# Report storage
REPORT_STORAGE_DRIVER="local"
REPORT_STORAGE_LOCAL_DIR="./storage/reports"
REPORT_STORAGE_PUBLIC_BASE_URL="http://localhost:3000/reports"
REPORT_BUCKET="agentproof-reports"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
PINATA_JWT=""
VERCEL_BLOB_READ_WRITE_TOKEN=""

# Web/API controls
# Public deployments should keep scan writes disabled unless a key is configured.
SCAN_API_ENABLED="false"
SCAN_API_REQUIRE_KEY="true"
SCAN_API_ALLOW_UNAUTHENTICATED="false"
SCAN_API_KEY=""
SCAN_REQUEST_SECRET=""
ADMIN_API_KEY=""
SCAN_TIMEOUT_MS="15000"
SCAN_MAX_REDIRECTS="3"
SCAN_USER_AGENT="CeloAgentPreflight/0.1 (+https://github.com/cleanerzkp/celo-agent-preflight)"
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_MAX_REQUESTS="30"
ENDPOINT_TIMEOUT_MS="5000"
MAX_ENDPOINTS_PER_AGENT="20"
MAX_RESPONSE_BYTES="1000000"
RESCAN_INTERVAL_HOURS="24"

# Security / observability
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Explorer / verification
ETHERSCAN_API_KEY=""
CELOSCAN_API_KEY=""
BLOCKSCOUT_API_KEY=""
NEXT_PUBLIC_CELOSCAN_BASE_URL="https://celoscan.io"
NEXT_PUBLIC_CELOSCAN_SEPOLIA_BASE_URL="https://sepolia.celoscan.io"
NEXT_PUBLIC_CELO_BLOCKSCOUT_BASE_URL="https://celo.blockscout.com"
SOURCIFY_API_BASE="https://sourcify.dev/server"
SOURCIFY_ENABLED="true"
