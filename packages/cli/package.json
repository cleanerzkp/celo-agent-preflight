{
  "name": "@celo-agent-preflight/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "celo-agent-preflight": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@celo-agent-preflight/preflight-core": "workspace:*",
    "@celo-agent-preflight/report-schema": "workspace:*",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
