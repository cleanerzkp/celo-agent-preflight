{
  "name": "celo-agent-preflight-workspace",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "build": "turbo run build",
    "ci": "pnpm doctor && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm foundry:fmt && pnpm foundry:test && pnpm security:secrets",
    "cli": "pnpm --filter @celo-agent-preflight/cli dev",
    "dev": "turbo run dev --parallel",
    "doctor": "node scripts/tool-doctor.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "security:deps": "pnpm audit --audit-level moderate",
    "security:secrets": "gitleaks dir . --redact --no-banner --config .gitleaks.toml",
    "security:osv": "osv-scanner scan source --lockfile pnpm-lock.yaml",
    "security:semgrep": "semgrep scan --config p/default --metrics=off .",
    "foundry:build": "cd contracts && forge build",
    "foundry:test": "cd contracts && forge test",
    "foundry:fmt": "cd contracts && forge fmt --check",
    "wrangler:version": "wrangler --version",
    "ctx7:whoami": "ctx7 whoami",
    "ctx7:setup": "ctx7 setup --mcp",
    "context7:mcp:version": "context7-mcp --version"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.51.2",
    "@coinbase/x402": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/evm": "^2.16.0",
    "viem": "^2.53.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@celo/celo-composer": "^2.4.13",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^24.10.0",
    "@upstash/context7-mcp": "^3.2.2",
    "ctx7": "^0.5.3",
    "next": "^16.2.9",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.104.0"
  }
}
